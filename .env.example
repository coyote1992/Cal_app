# ─── Photo → calorie estimation (added in a later step) ──────────────────────
# This app calls a vision LLM through OpenRouter (https://openrouter.ai).
# Create a key at https://openrouter.ai/keys and set it here (and in Vercel).
OPENROUTER_API_KEY=

# Which vision-capable model to use (any OpenAI-compatible model id on OpenRouter).
#   Cheap + excellent at vision:  google/gemini-2.0-flash-001
#   Strong all-rounder:           openai/gpt-4o
OPENROUTER_MODEL=openai/gpt-4o
